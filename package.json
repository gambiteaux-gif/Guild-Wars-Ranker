{
  "name": "guild-wars-performance-tracker",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:server\" \"npm:client\"",
    "client": "vite --host 0.0.0.0",
    "server": "node server/index.js",
    "build": "vite build",
    "start": "cross-env NODE_ENV=production node server/index.js",
    "preview": "vite preview --host 0.0.0.0",
    "check": "node --check server/index.js && node --check server/db.js && node --check server/scoring.js"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.4",
    "better-sqlite3": "^12.4.1",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "lucide-react": "^0.548.0",
    "recharts": "^3.3.0",
    "vite": "^7.1.12",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-router-dom": "^7.9.4"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "cross-env": "^10.0.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.18"
  }
}
